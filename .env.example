REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000

# ---- AI (Phase 3 - Groq, free tier) ----
GROQ_API_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
